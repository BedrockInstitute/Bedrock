#!/bin/sh
# Bedrock pre-commit: enforce prose conventions (full-width CJK punctuation,
# 「」 quotes, half-width Chinese parens, no em dash, no single quotes / nesting).
# Activated via: git config --local core.hooksPath scripts/git-hooks
# Bypass in an emergency with: git commit --no-verify

files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md|lagda\.md)$')
[ -z "$files" ] && exit 0

# shellcheck disable=SC2086
if ! python3 scripts/lint-prose.py --check $files; then
	echo ""
	echo "Prose lint failed. Auto-fix punctuation/quotes with:"
	echo "    python3 scripts/lint-prose.py --fix $files"
	echo "Em dashes, single quotes, and quote nesting must be rewritten by hand."
	echo "(To bypass: git commit --no-verify)"
	exit 1
fi
exit 0
